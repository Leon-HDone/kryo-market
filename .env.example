# ==================================
# Kryo Market - Environment Variables
# ==================================
# Kopiere diese Datei als .env und trage deine echten Werte ein.

# ─── Datenbank (wird von Railway automatisch gesetzt) ───
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Stripe (https://dashboard.stripe.com/apikeys) ───
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Resend (https://resend.com/api-keys) ───
RESEND_API_KEY=re_xxx
FROM_EMAIL=Kryo Market <noreply@deinedomain.de>

# ─── Frontend URL (für Stripe Redirects) ───
FRONTEND_URL=http://localhost:5173

# ─── Modus ───
NODE_ENV=development
